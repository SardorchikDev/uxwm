#!/bin/sh
# uxmenu_run - optional launcher wrapper for uxwm

set -eu

if command -v dmenu_run >/dev/null 2>&1; then
    exec dmenu_run "$@"
fi

if ! command -v dmenu >/dev/null 2>&1; then
    echo "uxmenu_run: requires dmenu or dmenu_run in PATH" >&2
    exit 1
fi

cmd=$(
    IFS=:
    for dir in $PATH; do
        [ -d "$dir" ] || continue
        find "$dir" -maxdepth 1 -type f -perm -111 -printf '%f\n' 2>/dev/null
    done | sort -u | dmenu "$@"
)

[ -n "$cmd" ] && exec "$cmd"
