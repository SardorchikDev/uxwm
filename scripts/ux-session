#!/bin/sh
# ux-session - launch uxwm with optional user hooks

set -eu

UXWM="${UXWM:-uxwm}"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/uxwm"
DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/uxwm"
AUTOSTART="$CONFIG_DIR/autostart"
STATUS_SCRIPT="$CONFIG_DIR/status.sh"

mkdir -p "$DATA_DIR"
exec >"$DATA_DIR/session.log" 2>&1

echo "Starting uxwm session at $(date)"

[ -f "$HOME/.Xresources" ] && xrdb -merge "$HOME/.Xresources"

if command -v xset >/dev/null 2>&1; then
    xset r rate 250 30 || true
    xset s off || true
    xset -dpms || true
fi

if [ -x "$STATUS_SCRIPT" ]; then
    echo "Running status hook..."
    "$STATUS_SCRIPT" &
fi

if [ -x "$AUTOSTART" ]; then
    echo "Running autostart hook..."
    "$AUTOSTART" &
fi

echo "Starting window manager..."
exec "$UXWM"
